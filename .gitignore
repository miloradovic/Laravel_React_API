# Environment files
.env
.env.*
!.env.example
backend/.env
backend/.env.*
!backend/.env.example
frontend/.env
frontend/.env.*
!frontend/.env.example

# Laravel backend dependencies and runtime files
backend/vendor/
backend/node_modules/
backend/bootstrap/cache/*.php
backend/bootstrap/cache/*.json
backend/storage/*.key
backend/storage/logs/
backend/storage/framework/cache/
backend/storage/framework/sessions/
backend/storage/framework/testing/
backend/storage/framework/views/

# Frontend dependencies and build output
frontend/node_modules/
frontend/dist/
frontend/.vite/

# Test and coverage output
backend/.phpunit.result.cache
coverage/

# IDE/editor files
.idea/
.vscode/
*.code-workspace

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Logs and temp files
*.log
*.tmp
*.temp
